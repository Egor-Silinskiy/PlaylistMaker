<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="MainButtonStyle" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/main_button</item>
        <item name="android:backgroundTint">@color/main_button_background</item>
        <item name="android:textSize">@dimen/button_text_size</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/corner_radius</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">@dimen/icon_padding</item>
        <item name="iconTint">@color/main_icon</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
    </style>

    <style name="SettingsImageStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center_vertical|end</item>
        <item name="android:layout_marginEnd">@dimen/second_padding_end</item>
        <item name="android:tint">@color/sett_image</item>
    </style>

    <style name="TitleTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_gravity">start</item>
        <item name="android:paddingTop">@dimen/padding_top</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textSize">@dimen/title_text_size</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
    </style>

    <style name="SettingsTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center_vertical|start</item>
        <item name="android:paddingStart">@dimen/second_padding_start</item>
        <item name="android:textSize">@dimen/second_text_size</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textColor">@color/sett_text</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
    </style>

    <style name="BlueCursorTheme">
        <item name="colorControlActivated">@color/cursor</item>
        <item name="colorAccent">@color/cursor</item>
    </style>

    <style name="TextTrack">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/track_text_size</item>
        <item name="android:textColor">@color/track_name_text</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textFontWeight">400</item>
    </style>

    <style name="TextArtist">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/artist_text_size</item>
        <item name="android:textColor">@color/track_icon</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textFontWeight">400</item>
    </style>

    <style name="ErrorLayout">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">102dp</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:orientation">vertical</item>
        <item name="android:visibility">gone</item>
    </style>

    <style name="ErrorImage">
        <item name="android:layout_width">120dp</item>
        <item name="android:layout_height">120dp</item>
        <item name="android:layout_gravity">center|top</item>
    </style>

    <style name="ErrorText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/er_text_margin_top</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_marginHorizontal">@dimen/er_text_margin_horizontal</item>
        <item name="android:textSize">@dimen/er_text_size</item>
        <item name="android:textColor">@color/text_error</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">400</item>
    </style>

    <style name="RefreshButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">@dimen/er_refresh_height</item>
        <item name="android:layout_marginTop">@dimen/er_refresh_margin_top</item>
        <item name="android:backgroundTint">@color/text_error</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:insetTop">@dimen/er_refresh_inset_vertical</item>
        <item name="android:insetBottom">@dimen/er_refresh_inset_vertical</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:paddingStart">@dimen/er_refresh_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/er_refresh_padding_horizontal</item>
        <item name="android:paddingVertical">@dimen/er_refresh_padding_vertical</item>
        <item name="android:textSize">@dimen/er_refresh_text_size</item>
        <item name="android:textColor">@color/text_button_error</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">500</item>
    </style>

    <style name="SearchHistoryText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:textSize">@dimen/search_history_text_size</item>
        <item name="android:textColor">@color/history_text</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:paddingTop">18dp</item>
        <item name="android:textFontWeight">500</item>
    </style>

    <style name="ClearHistoryButton" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name= "android:layout_width">wrap_content</item>
        <item name="android:layout_height">@dimen/search_history_button_height</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="cornerRadius">54dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:backgroundTint">@color/history_text</item>
        <item name="android:textColor">@color/button_clear</item>
    </style>






</resources>